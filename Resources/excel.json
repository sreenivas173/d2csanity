                    "mandatory": true,
                    "objectType": "dbtable"
                }
            }
        },
        "Validation Rules": {
            "table": {
                "DOMAIN": {
                    "mandatory": true,
                    "priority": "minor"
                },
                "TABLE_NAME": {
                    "mandatory": true,
                    "objectType": "dbtable"
                },
                "COLUMN_NAME": {
                    "mandatory": true,
                    "objectType": "dbcolumnList"
                },
                "VAL_ID": {
                    "mandatory": true,
                    "objectType": "dbtable"
                },
                "VALIDATION_NAME": {
                    "mandatory": true
                },
                "MAJORITY": {
                    "mandatory": true,
                    "objectType": "majority",
                    "default": "Major"
                },
                "VALIDATION_TYPE": {
                    "mandatory": true
                },
                "PARALLEL": {
                    "mandatory": false,
                    "objectType": "uint(2)"
                },
                "BUSINESS_RULE": {
                    "mandatory": true,
                    "priority": "minor",
