                "COLUMNS": {
                    "default": "SDB_VALUE",
                    "objectType": "dbcolumnList"
                }
            },
            "table": {
                "DICT_NAME": {
                    "mandatory": true,
                    "objectType": "dbtable"
                },
                "SDB_VALUE":{
                    "mandatory": true
                }
            }
        },
        "Source Dictionaries Structure": {
            "table": {
                "Hyperlink to sheet": {
                    "mandatory": true
                },
