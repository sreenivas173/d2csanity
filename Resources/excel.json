                    "mandatory": true
                }
            }
        },
        "Source Dictionaries": {
            "table": {
                "Hyperlink to sheet": {
                    "mandatory": true
                },
                "Sheet Name": {
                    "mandatory": true
                },
                "Source Dictionary Data":{
                    "mandatory": true,
                    "priority": "major",
                    "checkSepFile": true
                }
            }
        },
        "Source Dictionaries Structure Item": {
            "header": {
                "Table": {
                    "mandatory": true,
                    "objectType": "dbtable"
                }
            },
            "table": {
                "COLUMN_NAME": {
                    "mandatory": true,
                    "objectType": "dbtable"
                },
                "FIELD_DESCRIPTION": {
                    "mandatory": true,
                    "priority": "minor"
                },
                "DATATYPE": {
                    "mandatory": true,
                    "default": "VARCHAR2(200)"
                }
            }
        },
        "Source Dictionaries Item": {
            "header": {
                "Table": {
                    "mandatory": true,
                    "objectType": "dbtable"
                }
            },
            "table": {
                "COLUMN_NAME": {
                    "mandatory": true,
                    "objectType": "dbtable"
                },
                "FIELD_DESCRIPTION": {
                    "mandatory": true,
                    "priority": "minor"
                },
                "DATATYPE": {
                    "mandatory": true,
