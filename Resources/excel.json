{
    "objectType": {
        "dbtable": {
            "length": 128,
            "dbkeywords": "database_keywords.txt",
            "regexp": "^[A-Za-z][A-Za-z_0-9]*$"
        },
        "dbcolumn": {
            "length": 128,
            "dbkeywords": "database_keywords.txt",
            "regexp": "^[A-Za-z][A-Za-z_0-9]*$"
        },
        "dbcolumnList": {
            "length": 500,
            "dbkeywords": "database_keywords.txt",
            "regexp": "^([A-Za-z][A-Za-z_0-9,]*(->>'.+'|->'(.+'->>)+'.+')|[A-Za-z][A-Za-z_0-9,]*)$"
        },
        "dbtableList": {
            "length": 500,
            "dbkeywords": "database_keywords.txt",
            "regexp": "^[A-Za-z][A-Za-z_0-9,]*$"
        },
        "uint(2)": {
            "length": 2,
            "regexp": "^[1-9][0-9]{0,1}$"
        },
        "percent": {
            "length": 3,
            "regexp": "^(0|\\d{0,2}|100)$"
        },
        "majority": {
            "length": 9,
            "regexp": "^(Major|Minor|Technical)$"
        },
        "businesRule": {
            "length": 4000
        }
    },
    "sheetType": {
        "Table Set for Transformation": {
            "table": {
                "Sheet Name": {
                    "mandatory": true
                },
                "DOMAIN": {
                    "mandatory": true,
                    "priority": "minor"
                },
                "Hyperlink to sheet": {
                    "mandatory": true
                }
            }
        },
        "Table Set for Transformation Item": {
            "header": {
                "Table": {
                    "mandatory": true,
                    "objectType": "dbtable"
                },
                "Transformation rules": {
                    "mandatory": true,
                    "checkSepFile": true
                },
                "Primary Key": {
                    "mandatory": true
                },
                "PARALLEL": {
                    "mandatory": false,
                    "objectType": "uint(2)"
                },
                "PCTFREE": {
                    "mandatory": false,
                    "objectType": "percent",
                    "default": "0"
                },
                "Synonym": {
                    "mandatory": false,
                    "objectType": "dbtable"
                },
                "Source Tables": {
                    "mandatory": true,
                    "objectType": "dbtableList"
                },
                "Source Descriptor": {
                    "mandatory": true
                }
            },
            "table": {
                "COLUMN_NAME": {
                    "mandatory": true,
                    "objectType": "dbcolumn"
                },
                "DATATYPE": {
                    "mandatory": true,
                    "default": "VARCHAR2(200)"
                },
                "FIELD_DESCRIPTION": {
                    "mandatory": true,
                    "priority": "minor"
                },
                "TRANSFORMATION": {
                    "mandatory": true,
                    "priority": "minor"
                },
                "REFERENTIAL_CLAUSE": {
                    "objectType": "dbcolumnList"
                }
            }
        },
        "Source Data Structure": {
            "table": {
                "Sheet Name": {
                    "mandatory": true
                },
                "Hyperlink to sheet": {
                    "mandatory": true
                }
            }
        },
        "Source Data Structure Item": {
            "header": {
                "Table": {
                    "mandatory": true,
                    "objectType": "dbtable"
                }
            },
            "table": {
                "COLUMN_NAME": {
                    "mandatory": true,
                    "objectType": "dbcolumn"
                },
                "DATATYPE": {
                    "mandatory": true,
                    "default": "VARCHAR2(200)"
                },
                "FIELD_DESCRIPTION": {
                    "mandatory": true,
                    "priority": "minor"
                }
            }
        },
        "Revision": {
            "table": {
                "Author": {
                    "mandatory": true
                },
                "Date": {
                    "mandatory": true
                },
                "Description of Change": {
                    "mandatory": true
                },
                "Version": {
                    "mandatory": true
                }
            }
        },
        "Common Dictionaries": {
