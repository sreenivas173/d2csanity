                    "objectType": "dbtable"
                },
                "CLEAR_DATA": {
                    "mandatory": true,
                    "objectType": "dbtable"
                },
                "BUSINESS_RULE": {
                    "mandatory": true,
                    "priority": "minor"
                },
                "REFERENTIAL_ENTITY": {
                    
                },
                "REFERENTIAL_CLAUSE": {
                    
                }
            }
        },
        "Common Data Structure": {
            "table":{
                "TABLE_NAME": {
                    "mandatory": true,
                    "objectType": "dbtable"
                },
                "COLUMN_NAME": {
                    "mandatory": true,
                    "objectType": "dbcolumn"
                },
                "DATATYPE": {
                    "mandatory": true,
                    "default": "VARCHAR2(200)"
